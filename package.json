{
  "name": "scs-discord-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Unified Discord bot for the SCS Hockey League website. Replaces ticketing, leveling, polls, embeds, pickems, casino, moderation, and counters with one tightly-integrated bot.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "deploy": "tsx src/deploy.ts"
  },
  "dependencies": {
    "@discordjs/opus": "^0.9.0",
    "@discordjs/voice": "^0.18.0",
    "@supabase/supabase-js": "^2.45.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "libsodium-wrappers": "^0.7.13",
    "node-fetch": "^3.3.2",
    "openai": "^4.73.0",
    "prism-media": "^1.3.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
